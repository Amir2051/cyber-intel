# ─────────────────────────────────────────────
#  CyberIntel Platform — Environment Variables
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# ── OSINT / Email Intelligence ────────────────
HUNTER_API_KEY=
ABSTRACT_API_KEY=

# ── Infra / Domain / Host Intel ───────────────
SHODAN_API_KEY=

# ── Phone Validation ──────────────────────────
NUMVERIFY_API_KEY=

# ── WHOIS ─────────────────────────────────────
WHOISXML_API_KEY=

# ── Blockchain / Crypto ───────────────────────
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
TRONSCAN_API_KEY=
BLOCKCHAIN_API_KEY=

# ── Dark Web / Breach Data ────────────────────
DEHASHED_API_KEY=
DEHASHED_EMAIL=

# ── Property Data ─────────────────────────────
ATTOM_API_KEY=

# ── Supabase (frontend env in frontend/.env.local) ──
# Used as a placeholder reference; frontend reads its own .env.local
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# ── Storage Paths ─────────────────────────────
REPORTS_DIR=/tmp/cyberintel_reports
MONITOR_DB=/tmp/cyberintel_monitors.json
ALERTS_DB=/tmp/cyberintel_alerts.json

# ── Server ────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Comma-separated allowlist. Use a specific list in production.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
